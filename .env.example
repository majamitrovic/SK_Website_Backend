FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=
BACKEND_BASE_URL=

ALLSECURE_USERNAME=replace_with_api_username
ALLSECURE_PASSWORD=replace_with_api_password
ALLSECURE_CONNECTOR_API_KEY=replace_with_connector_api_key
ALLSECURE_CONNECTOR_SHARED_SECRET=replace_with_connector_shared_secret
ALLSECURE_PUBLIC_INTEGRATION_KEY=replace_with_public_integration_key

# Live defaults. For sandbox, use https://asxgw.paymentsandbox.cloud/
ALLSECURE_GATEWAY_URL=https://asxgw.com/
ALLSECURE_PAYMENT_JS_URL=https://asxgw.com/js/integrated/payment.1.3.min.js

ALLSECURE_LANGUAGE=en
ALLSECURE_DEFAULT_AMOUNT=9.99
ALLSECURE_DEFAULT_CURRENCY=EUR
ALLSECURE_DEFAULT_DESCRIPTION=Website payment

# Valid values commonly used by the gateway: OFF, OPTIONAL, MANDATORY
ALLSECURE_3DSECURE=MANDATORY

# Keep enabled in production. Callback validation requires the shared secret.
ALLSECURE_VALIDATE_CALLBACKS=true

# Optional on Windows/local PHP installs where curl.cainfo is not configured.
# Use a relative path from the project root or an absolute path.
ALLSECURE_CURL_CAINFO=
