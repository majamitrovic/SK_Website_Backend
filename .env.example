FRONTEND_BASE_URL=https://example.com/
BACKEND_BASE_URL=https://api.example.com/

FRONTEND_ALLOWED_ORIGINS=https://example.com,http://localhost:5173,http://127.0.0.1:5173

ALLSECURE_USERNAME=your_allsecure_username
ALLSECURE_PASSWORD=your_allsecure_password
ALLSECURE_CONNECTOR_API_KEY=your_connector_api_key
ALLSECURE_CONNECTOR_SHARED_SECRET=your_connector_shared_secret
ALLSECURE_PUBLIC_INTEGRATION_KEY=your_public_integration_key

# Sandbox gateway
ALLSECURE_GATEWAY_URL=https://asxgw.paymentsandbox.cloud/
ALLSECURE_PAYMENT_JS_URL=https://asxgw.paymentsandbox.cloud/js/integrated/payment.1.3.min.js

ALLSECURE_LANGUAGE=en
ALLSECURE_DEFAULT_AMOUNT=500
ALLSECURE_DEFAULT_CURRENCY=RSD
ALLSECURE_DEFAULT_DESCRIPTION=Website payment

ALLSECURE_3DSECURE=MANDATORY

ALLSECURE_VALIDATE_CALLBACKS=true

ALLSECURE_CURL_CAINFO=

# Gateway Error Handling
GATEWAY_ERROR_LANGUAGE=sr
GATEWAY_SHOW_ADAPTER_DETAILS=false

# Mail Settings
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Payment System

# Gmail SMTP Configuration
# To get your app password:
# 1. Enable 2-Factor Authentication: https://myaccount.google.com/security
# 2. Generate app password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer" (or your device)
# 4. Google will generate a 16-character password
# 5. Paste it below in MAIL_SMTP_PASSWORD
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your_gmail@gmail.com
MAIL_SMTP_PASSWORD=your_app_password
MAIL_SMTP_ENCRYPTION=tls

# Support email for user inquiries
SUPPORT_EMAIL=support@example.com
COMPANY_NAME=Your Company Name
PAYMENT_ADMIN_EMAIL=admin@example.com

# Database Configuration
# Supported types: sqlite, mysql, pgsql
# SQLite is recommended for free hosting (no server required)
DB_TYPE=sqlite

# MySQL Configuration (optional, if using MySQL)
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=payments
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL Configuration (optional, if using PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=payments
# DB_USERNAME=postgres
# DB_PASSWORD=

# Logging Configuration
ENABLE_LOGGING=true
ENABLE_DATABASE_LOGGING=false